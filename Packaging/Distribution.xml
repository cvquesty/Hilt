<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Hilt</title>
    <organization>org.questy</organization>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <options customize="never" require-scripts="false" rootVolumeOnly="true" hostArchitectures="x86_64,arm64"/>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <license file="LICENSE" mime-type="text/plain"/>
    <pkg-ref id="org.questy.hilt"/>
    <choices-outline>
        <line choice="default">
            <line choice="org.questy.hilt"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="org.questy.hilt" visible="false">
        <pkg-ref id="org.questy.hilt"/>
    </choice>
    <pkg-ref id="org.questy.hilt" version="0.2.0" onConclusion="none">Hilt-component.pkg</pkg-ref>
</installer-gui-script>
